# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUPABASE_SERVICE_ROLE_KEY=# ⚠️ NEVER expose service role key to client

# Anthropic AI
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Mistral AI (Fallback 1)
# Get from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-key-here

# Groq (Fallback 2)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here

# Upstash Redis (Rate Limiting)
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_API_KEY=

# Resend (Email Service)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Unsplash (Image Search)
# Get from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-access-key-here

# Sentry (Error Tracking)
# Get from: https://sentry.io/settings/projects
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/id

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
